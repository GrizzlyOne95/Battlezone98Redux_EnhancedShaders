import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abtowe00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abtowe_D.dds
	set_texture_alias NormalMap abtowe_n.dds
	set_texture_alias SpecularMap abtowe_S.dds
	set_texture_alias EmissiveMap abtowe_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.63"
	set $emissiveAnimSpeed "2.14"
	set $emissiveAnimScale "17.6"
}



