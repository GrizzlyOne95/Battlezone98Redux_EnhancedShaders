import * from "CR_BZBase.material"

material abtowe00 : CR_BZBase
{
	set_texture_alias DiffuseMap abtowe_D.dds
	set_texture_alias NormalMap flat_N.png
	set_texture_alias SpecularMap abtowe_S.dds
	set_texture_alias EmissiveMap abtowe_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}



