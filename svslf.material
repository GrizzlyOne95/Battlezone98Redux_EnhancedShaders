import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material svslf00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap svslf_d.dds
	set_texture_alias NormalMap svslf_N.dds
	set_texture_alias SpecularMap svslf_S.dds
	set_texture_alias EmissiveMap svslf_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.8"
	set $emissiveAnimSpeed "2.86"
	set $emissiveAnimScale "18.9"
}








