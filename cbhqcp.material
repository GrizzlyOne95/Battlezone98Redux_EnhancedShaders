import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material CBHQCM : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbhqcp_d.dds
	set_texture_alias NormalMap cbhqcp_n.dds
	set_texture_alias SpecularMap cbhqcp_S.dds
	set_texture_alias EmissiveMap cbhqcp_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.65"
	set $emissiveAnimSpeed "0.92"
	set $emissiveAnimScale "10.0"
}







