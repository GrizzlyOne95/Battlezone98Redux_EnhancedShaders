import * from "CR_BZBase.material"

material CBHQCM : CR_BZBase
{
	set_texture_alias DiffuseMap cbhqcp_d.dds
	set_texture_alias NormalMap flat_n.dds
	set_texture_alias SpecularMap cbhqcp_S.dds
	set_texture_alias EmissiveMap cbhqcp_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}







