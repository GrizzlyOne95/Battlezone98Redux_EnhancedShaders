import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abmbld : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abmbld_D.dds
	set_texture_alias NormalMap abmbld_n.dds
	set_texture_alias SpecularMap abmbld_S.dds
	set_texture_alias EmissiveMap abmbld_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.52"
	set $emissiveAnimSpeed "2.95"
	set $emissiveAnimScale "4.5"
}





