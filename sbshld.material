import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sbshld00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbshld_d.dds
	set_texture_alias NormalMap sbshld_n.dds
	set_texture_alias SpecularMap sbshld_S.dds
	set_texture_alias EmissiveMap sbshld_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.27"
	set $emissiveAnimSpeed "1.48"
	set $emissiveAnimScale "18.1"
}





