import * from "CR_BZBase.material"

material svmuf00 : CR_BZBase
{
	set_texture_alias DiffuseMap svmuf_d.dds
	set_texture_alias NormalMap svmuf_N.dds
	set_texture_alias SpecularMap svmuf_S.dds
	set_texture_alias EmissiveMap svmuf_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}








