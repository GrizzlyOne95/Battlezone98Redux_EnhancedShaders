material STARS.MAP
{
	technique
	{
		pass
		{
			vertex_program_ref CR_Sky_vertex
			{
			}
			fragment_program_ref CR_Sky_fragment
			{
				param_named starThreshold float 0.70
				param_named twinkleStrength float 20.0
				param_named twinkleSpeed float 10.0
				param_named twinkleScale float 600.0
				param_named twinkleMin float 0.0
			}

			cull_hardware none
			cull_software none 
			lighting off
			fog_override true none
			scene_blend alpha_blend
			depth_write off
			diffuse vertexcolour
			texture_unit
			{
				tex_address_mode clamp
				texture stars.png
			}
		}
	}
}
