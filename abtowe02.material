import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abtowe02 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abtowe02_D.dds
	set_texture_alias NormalMap abtowe02_n.dds
	set_texture_alias SpecularMap abtowe02_S.dds
	set_texture_alias EmissiveMap black.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.26"
	set $emissiveAnimSpeed "0.71"
	set $emissiveAnimScale "17.7"
}



