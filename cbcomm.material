import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"


material CBCOMM : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbcomm_d.dds
	set_texture_alias NormalMap cbcomm_n.dds
	set_texture_alias SpecularMap cbcomm_S.dds
	set_texture_alias EmissiveMap cbcomm_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.16"
	set $emissiveAnimSpeed "1.16"
	set $emissiveAnimScale "15.5"
}






