import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sblpow00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sblpow_d.dds
	set_texture_alias NormalMap sblpow_n.dds
	set_texture_alias SpecularMap sblpow_S.dds
	set_texture_alias EmissiveMap sblpow_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.64"
	set $emissiveAnimSpeed "2.76"
	set $emissiveAnimScale "12.5"
}





