import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material apmort00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap apmort00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap apmort00_S.dds
	set_texture_alias EmissiveMap apmort00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.38"
	set $emissiveAnimSpeed "2.41"
	set $emissiveAnimScale "19.1"
}




