import * from "CR_BZBase.material"

material bbstor : CR_BZBase
{
	set_texture_alias DiffuseMap bbstor_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap bbstor_S.dds
	set_texture_alias EmissiveMap bbstor_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}




