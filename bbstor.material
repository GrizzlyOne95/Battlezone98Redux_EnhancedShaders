import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bbstor : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbstor_D.dds
	set_texture_alias NormalMap bbstor_n.dds
	set_texture_alias SpecularMap bbstor_S.dds
	set_texture_alias EmissiveMap bbstor_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.26"
	set $emissiveAnimSpeed "1.21"
	set $emissiveAnimScale "5.7"
}




