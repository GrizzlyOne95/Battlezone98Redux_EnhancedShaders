import * from "CR_BZBase.material"

material svheadlight00 : CR_BZBase
{
	set_texture_alias DiffuseMap svheadlight00_d.dds
	set_texture_alias NormalMap   flat_N.dds
	set_texture_alias SpecularMap svheadlight00_S.dds
	set_texture_alias EmissiveMap svheadlight00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}
