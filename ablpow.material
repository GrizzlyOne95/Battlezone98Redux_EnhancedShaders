import * from "CR_BZBase.material"

material ablpow : CR_BZBase
{
	set_texture_alias DiffuseMap ablpow_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap ablpow_S.dds
	set_texture_alias EmissiveMap ablpow_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}


