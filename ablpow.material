import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material ablpow : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap ablpow_D.dds
	set_texture_alias NormalMap ablpow_n.dds
	set_texture_alias SpecularMap ablpow_S.dds
	set_texture_alias EmissiveMap ablpow_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.8"
	set $emissiveAnimSpeed "2.44"
	set $emissiveAnimScale "10.7"
}


