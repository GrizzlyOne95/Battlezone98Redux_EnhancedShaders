import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"


material bbspow : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbspow_D.dds
	set_texture_alias NormalMap bbspow_n.dds
	set_texture_alias SpecularMap bbspow_S.dds
	set_texture_alias EmissiveMap abspow_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.42"
	set $emissiveAnimSpeed "2.33"
	set $emissiveAnimScale "12.2"
}


