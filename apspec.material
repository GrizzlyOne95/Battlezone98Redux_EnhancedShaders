import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material apspec00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap apspec00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap apspec00_S.dds
	set_texture_alias EmissiveMap apspec00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.21"
	set $emissiveAnimSpeed "2.46"
	set $emissiveAnimScale "17.7"
}


