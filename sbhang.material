import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sbhang : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbhang_d.dds
	set_texture_alias NormalMap sbhang_n.dds
	set_texture_alias SpecularMap sbhang_S.dds
	set_texture_alias EmissiveMap sbhang_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.7"
	set $emissiveAnimSpeed "0.98"
	set $emissiveAnimScale "12.3"
}





