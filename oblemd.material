import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material oblemd : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap oblemb00_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap oblemb00_S.dds
	set_texture_alias EmissiveMap black.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.71"
	set $emissiveAnimSpeed "0.63"
	set $emissiveAnimScale "19.9"
}





