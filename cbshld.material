import * from "CR_BZBase.material"

material cbshld00 : CR_BZBase
{
	set_texture_alias DiffuseMap cbshld_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap cbshld_S.dds
	set_texture_alias EmissiveMap cbshld_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}





