import * from "CR_BZBase.material"

material sbtowe : CR_BZBase
{
	set_texture_alias DiffuseMap sbtowe_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap sbtowe_S.dds
	set_texture_alias EmissiveMap sbtowe_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}







