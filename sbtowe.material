import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sbtowe : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbtowe_d.dds
	set_texture_alias NormalMap sbtowe_n.dds
	set_texture_alias SpecularMap sbtowe_S.dds
	set_texture_alias EmissiveMap sbtowe_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.71"
	set $emissiveAnimSpeed "0.42"
	set $emissiveAnimScale "14.8"
}







