import * from "CR_BZBase.material"

material magpull : CR_BZBase
{
	set_texture_alias DiffuseMap magpull00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap black.dds
	set_texture_alias EmissiveMap magpull00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $bias "0"
}




