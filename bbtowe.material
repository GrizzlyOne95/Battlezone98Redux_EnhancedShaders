import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bbtowe00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbtowe_D.dds
	set_texture_alias NormalMap bbtowe_n.dds
	set_texture_alias SpecularMap bbtowe_S.dds
	set_texture_alias EmissiveMap bbtowe_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.28"
	set $emissiveAnimSpeed "2.28"
	set $emissiveAnimScale "12.9"
}


