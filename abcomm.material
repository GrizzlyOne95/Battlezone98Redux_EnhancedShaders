import * from "CR_BZBase.material"

material abcomm : CR_BZBase
{
	set_texture_alias DiffuseMap abcomm_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap abcomm_S.dds
	set_texture_alias EmissiveMap abcomm_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}



