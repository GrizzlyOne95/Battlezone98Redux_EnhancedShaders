import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abcomm : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abcomm_D.dds
	set_texture_alias NormalMap abcomm_n.dds
	set_texture_alias SpecularMap abcomm_S.dds
	set_texture_alias EmissiveMap abcomm_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.63"
	set $emissiveAnimSpeed "0.56"
	set $emissiveAnimScale "12.4"
}



