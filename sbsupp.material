import * from "CR_BZBase.material"

material sbsupp00 : CR_BZBase
{
	set_texture_alias DiffuseMap sbsupp_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap sbsupp_S.dds
	set_texture_alias EmissiveMap sbsupp_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}





