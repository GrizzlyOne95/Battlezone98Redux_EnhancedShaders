import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sbsupp00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbsupp_d.dds
	set_texture_alias NormalMap sbsupp_n.dds
	set_texture_alias SpecularMap sbsupp_S.dds
	set_texture_alias EmissiveMap sbsupp_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.17"
	set $emissiveAnimSpeed "1.23"
	set $emissiveAnimScale "15.2"
}





