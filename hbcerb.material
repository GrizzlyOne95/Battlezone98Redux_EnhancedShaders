import * from "CR_BZBase.material"

material hbcerb00 : CR_BZBase
{
	set_texture_alias DiffuseMap hbcerb00_D.dds
	set_texture_alias NormalMap hbcerb00_N.dds
	set_texture_alias SpecularMap hbcerb00_S.dds
	set_texture_alias EmissiveMap hbcerb00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}


