import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material svrecy00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap svrecy_d.dds
	set_texture_alias NormalMap svrecy_N.dds
	set_texture_alias SpecularMap svrecy_S.dds
	set_texture_alias EmissiveMap svrecy_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.8"
	set $emissiveAnimSpeed "1.64"
	set $emissiveAnimScale "12.5"
}








