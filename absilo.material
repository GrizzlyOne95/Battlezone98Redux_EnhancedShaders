import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material absilo003 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap absilo_D.dds
	set_texture_alias NormalMap absilo_n.dds
	set_texture_alias SpecularMap absilo_S.dds
	set_texture_alias EmissiveMap absilo_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.41"
	set $emissiveAnimSpeed "0.99"
	set $emissiveAnimScale "19.5"
}




