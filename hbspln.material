import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material hbspln : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap hbpow00_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap hbpow00_S.dds
	set_texture_alias EmissiveMap hbpow00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.52"
	set $emissiveAnimSpeed "1.87"
	set $emissiveAnimScale "17.7"
}





