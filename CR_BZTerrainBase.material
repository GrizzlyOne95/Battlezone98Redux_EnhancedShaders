	}
	fragment_program_ref CR_TerrainLowestShadow_fragment
	{
		param_named tileBlendStrength float $tileBlendStrength
		param_named detailNormalStrength float $detailNormalStrength
		param_named glossStrength float $glossStrength
		param_named glossBias float $glossBias
