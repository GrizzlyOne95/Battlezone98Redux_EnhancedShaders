abstract pass CR_BZTerrainPassSchemeLowestPSSM
{
	vertex_program_ref CR_TerrainLowestPSSM_vertex
	{
	}
	fragment_program_ref CR_TerrainLowestPSSM_fragment
	{
		param_named tileBlendStrength float $tileBlendStrength
		param_named detailNormalStrength float $detailNormalStrength
		param_named glossStrength float $glossStrength
		param_named glossBias float $glossBias
		param_named metallicStrength float $metallicStrength
		param_named metallicBias float $metallicBias
		param_named terrainNormalStrength float $terrainNormalStrength
		param_named terrainDiffuseBoost float $terrainDiffuseBoost
		param_named objectAmbientStrength float $objectAmbientStrength
		param_named detailContrastStrength float $detailContrastStrength
		param_named detailFadeStart float $detailFadeStart
		param_named detailFadeRange float $detailFadeRange
		param_named slopeDetailStrength float $slopeDetailStrength
		param_named specAAStrength float $specAAStrength
		param_named wrapDiffuse float $wrapDiffuse
		param_named rimStrength float $rimStrength
		param_named rimPower float $rimPower
		param_named emissiveAnimStrength float $emissiveAnimStrength
		param_named emissiveAnimSpeed float $emissiveAnimSpeed
		param_named emissiveAnimScale float $emissiveAnimScale
		param_named_auto baseTime time_0_x 1.0
		param_named materialShininess float $shininess
	} 
	
	scene_blend alpha_blend
	depth_func less_equal
	
	ambient $ambient
	diffuse $diffuse
	specular $specular $shininess
	depth_bias $bias

	texture_unit diffuseMap
	{
		texture_alias DiffuseMap
		texture white.png
	}
	
	texture_unit detailMap
	{
		texture_alias DetailMap
		texture white.png 
	}

	texture_unit normalMap
	{
		texture_alias NormalMap
		texture flat_n.png 2d
	}

	texture_unit specularMap
	{
		texture_alias SpecularMap
		texture white.png 2d
	}

	texture_unit emissiveMap
	{
		texture_alias EmissiveMap
		texture black.png 2d
	}

	texture_unit glossMap
	{
		texture_alias GlossMap
		texture black.png 2d
	}

	texture_unit metallicMap
	{
		texture_alias MetallicMap
		texture black.png 2d
	}
	texture_unit detailNormalMap
	{
		texture_alias DetailNormalMap
		texture flat_n.png 2d
	}

	texture_unit shadowMap1
	{
		content_type shadow
		tex_address_mode border
		tex_border_colour 1.0 1.0 1.0 1.0
	}

	texture_unit shadowMap2
	{
		content_type shadow
		tex_address_mode border
		tex_border_colour 1.0 1.0 1.0 1.0
	}

	texture_unit shadowMap3
	{
		content_type shadow
		tex_address_mode border
		tex_border_colour 1.0 1.0 1.0 1.0
	}
}

abstract pass CR_BZTerrainPassSchemeLowest
{
	vertex_program_ref CR_TerrainLowestShadow_vertex
