set $tileBlendStrength 0.0
set $detailNormalStrength 1.15
set $glossStrength 1.0
set $glossBias 0.0
set $metallicStrength 1.0
set $metallicBias 0.0
set $terrainNormalStrength 1.25
set $terrainDiffuseBoost 1.0
set $objectAmbientStrength 1.0
set $detailContrastStrength 0.85
set $detailFadeStart 40.0
set $detailFadeRange 120.0
set $slopeDetailStrength 0.0
set $specAAStrength 1.0
set $wrapDiffuse 0.25
set $rimStrength 1.0
set $rimPower 4.0
set $emissiveAnimStrength 0.0
set $emissiveAnimSpeed 1.0
set $emissiveAnimScale 6.0
set $glow 0 0 0 1

set $ambient 1 1 1 1
set $diffuse 1 1 1 1
set $specular 0.5 0.5 0.5 1
set $shininess 32
set $bias 0

