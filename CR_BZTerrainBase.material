material CR_BZTerrainBase
{
	set $shininess "32"
    set $ambient "1 1 1"
    set $diffuse "1 1 1"
	set $specular "1 1 1"
	set $bias "0"
	set $glow "1 1 1"
	
	
	lod_values 256 512
	lod_strategy Distance	
	
    technique
    {
        scheme high-pssm
        lod_index 0
		
		pass : CR_BZTerrainPassSchemeHighPSSM
 		{
		}
    }
	
    technique
    {
        scheme high-pssm
        lod_index 1
		
		pass : CR_BZTerrainPassSchemeHighNoShadow
 		{
		}
    }

	technique
    {
        scheme high-pssm
        lod_index 2
		
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }

    technique
    {
        scheme high	 	
        lod_index 0
		
		pass : CR_BZTerrainPassSchemeHigh
 		{
		}
    }
	
    technique
    {
        scheme high	 	
        lod_index 1
		
		pass : CR_BZTerrainPassSchemeHighNoShadow
 		{
		}
    }

	technique
    {
        scheme high
        lod_index 2
		
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }

    technique
    {
        scheme high-noshadow	
        lod_index 0
		
		pass : CR_BZTerrainPassSchemeHighNoShadow
 		{
		}
    }
	
    technique
    {
        scheme high-noshadow	 	
        lod_index 1
		
		pass : CR_BZTerrainPassSchemeHighNoShadow
 		{
		}
    }

	technique
    {
        scheme high-noshadow
        lod_index 2
		
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }
	
    technique
    {
        scheme medium-pssm
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeMediumPSSM
 		{
		}
    }

    technique
    {
        scheme medium-pssm
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }

    technique
    {
        scheme medium-pssm
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme medium
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeMedium
 		{
		}
    }

    technique
    {
        scheme medium
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }

    technique
    {
        scheme medium
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme medium-noshadow
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }

    technique
    {
        scheme medium-noshadow
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeMediumNoShadow
 		{
		}
    }

    technique
    {
        scheme medium-noshadow
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-pssm
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeLowPSSM
 		{
		}
    }

    technique
    {
        scheme low-pssm
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-pssm
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeLow
 		{
		}
    }

    technique
    {
        scheme low
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-noshadow
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-noshadow
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-noshadow
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-pssm
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeLowestPSSM
 		{
		}
    }

    technique
    {
        scheme lowest-pssm
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-pssm
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeLowest
 		{
		}
    }

    technique
    {
        scheme lowest
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-noshadow
        lod_index 0
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-noshadow
        lod_index 1
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-noshadow
        lod_index 2
		  
		pass : CR_BZTerrainPassSchemeLowestNoShadow
 		{
		}
    }

	technique
	{
		scheme glow

		pass
 		{
			vertex_program_ref CR_TerrainGlow_vertex
			{
			}
			fragment_program_ref CR_TerrainGlow_fragment
			{
				param_named fogColour float3 0 0 0
			}

			scene_blend alpha_blend
			depth_func less_equal

			ambient $glow 
			diffuse $glow 
			depth_bias $bias

			texture_unit emissiveMap
			{
				texture_alias EmissiveMap
				texture black.png 2d
			}
		}
	}
}

material CR_BZTerrainBaseDebug
{
	lod_values 2560
	lod_strategy Distance

    technique
    {
        scheme high		
        lod_index 0
		
		pass 
 		{
			diffuse 1 0 0 1
		}
    }
	
	technique
    {
        scheme high		
        lod_index 1
		
		pass 
 		{
		
			diffuse 0 0 1 0
		}
    }

	technique
    {
        scheme high		
        lod_index 2
		
		pass 
 		{
		
			diffuse 0 1 0 0
		}
    }	
}

