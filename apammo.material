import * from "CR_BZBase.material"

material apammo00 : CR_BZBase
{
	set_texture_alias DiffuseMap apammo00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap apammo00_S.dds
	set_texture_alias EmissiveMap apammo00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}




