import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material apammo00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap apammo00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap apammo00_S.dds
	set_texture_alias EmissiveMap apammo00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.73"
	set $emissiveAnimSpeed "1.72"
	set $emissiveAnimScale "10.8"
}




