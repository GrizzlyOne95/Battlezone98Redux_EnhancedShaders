import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material hvrckt : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap hbsav00_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap hbsav00_S.dds
	set_texture_alias EmissiveMap hbsav00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.18"
	set $emissiveAnimSpeed "2.79"
	set $emissiveAnimScale "6.2"
}




