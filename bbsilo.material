import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bbsilo00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbsilo_D.dds
	set_texture_alias NormalMap bbsilo_n.dds
	set_texture_alias SpecularMap bbsilo_S.dds
	set_texture_alias EmissiveMap bbsilo_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.55"
	set $emissiveAnimSpeed "2.02"
	set $emissiveAnimScale "15.0"
}


