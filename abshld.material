import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abshld : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abshld_D.dds
	set_texture_alias NormalMap abshld_n.dds
	set_texture_alias SpecularMap abshld_S.dds
	set_texture_alias EmissiveMap abshld_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.49"
	set $emissiveAnimSpeed "2.11"
	set $emissiveAnimScale "19.7"
}

