import * from "CR_BZBase.material"


material bbmbld : CR_BZBase
{
	set_texture_alias DiffuseMap bbmbld_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap bbmbld_S.dds
	set_texture_alias EmissiveMap abmbld_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}


