import * from "CR_BZBase.material"

material CBLPAD : CR_BZBase
{
	set_texture_alias DiffuseMap cblpad_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap cblpad_S.dds
	set_texture_alias EmissiveMap cblpad_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}






