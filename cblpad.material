import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material CBLPAD : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cblpad_d.dds
	set_texture_alias NormalMap cblpad_n.dds
	set_texture_alias SpecularMap cblpad_S.dds
	set_texture_alias EmissiveMap cblpad_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.38"
	set $emissiveAnimSpeed "1.72"
	set $emissiveAnimScale "4.4"
}






