import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material CBSUPP : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbsmbld_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap cbsmbld_S.dds
	set_texture_alias EmissiveMap cbsmbld_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.33"
	set $emissiveAnimSpeed "1.41"
	set $emissiveAnimScale "16.4"
}





