import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"


material bbshld : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbshld_D.dds
	set_texture_alias NormalMap bbshld_n.dds
	set_texture_alias SpecularMap bbshld_S.dds
	set_texture_alias EmissiveMap abshld_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.57"
	set $emissiveAnimSpeed "2.04"
	set $emissiveAnimScale "8.3"
}


