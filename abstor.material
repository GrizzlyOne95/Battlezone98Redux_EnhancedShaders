import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abstor : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abstor_D.dds
	set_texture_alias NormalMap abstor_n.dds
	set_texture_alias SpecularMap abstor_S.dds
	set_texture_alias EmissiveMap abstor_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.51"
	set $emissiveAnimSpeed "0.89"
	set $emissiveAnimScale "11.0"
}




