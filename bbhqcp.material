import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bbhqcp00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbhqcp_D.dds
	set_texture_alias NormalMap bbhqcp_n.dds
	set_texture_alias SpecularMap bbhqcp_S.dds
	set_texture_alias EmissiveMap bbhqcp_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.84"
	set $emissiveAnimSpeed "1.88"
	set $emissiveAnimScale "19.9"
}


