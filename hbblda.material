import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material hbstyx00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap hbstyx00.dds
	set_texture_alias NormalMap flat.dds
	set_texture_alias SpecularMap hbstyx00_S.dds
	set_texture_alias EmissiveMap hbstyx00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.75"
	set $emissiveAnimSpeed "2.4"
	set $emissiveAnimScale "10.7"
}



