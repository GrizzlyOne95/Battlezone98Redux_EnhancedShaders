import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material apcamr00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap apcamr00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap apcamr00_S.dds
	set_texture_alias EmissiveMap apcamr00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.6"
	set $emissiveAnimSpeed "1.95"
	set $emissiveAnimScale "11.6"
}




