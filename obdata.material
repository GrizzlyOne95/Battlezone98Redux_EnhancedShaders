import * from "CR_BZBase.material"

material obdata : CR_BZBase
{
	set_texture_alias DiffuseMap obdata00_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap obdata00_S.dds
	set_texture_alias EmissiveMap obdata00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}





