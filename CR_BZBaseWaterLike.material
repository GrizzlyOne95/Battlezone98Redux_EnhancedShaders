import * from "CR_BZBase.material"

// Water-like: highly reflective, wet, or liquid-like surfaces.
// Low metallic (dielectric), high specular, strong gloss, sharp rim.
abstract material CR_BZBaseWaterLike : CR_BZBase
{
	set $objectSpecPower "1.38"
	set $objectAmbientStrength "0.82"
	set $objectIBLDiffuseStrength "0.86"
	set $objectIBLSpecStrength "1.10"
	set $glossStrength "1.26"
	set $glossBias "0.08"
	set $metallicStrength "0.10"
	set $metallicBias "-0.20"
}
