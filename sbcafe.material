import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sbcafe : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbcafe_d.dds
	set_texture_alias NormalMap sbcafe_n.dds
	set_texture_alias SpecularMap sbcafe_S.dds
	set_texture_alias EmissiveMap sbcafe_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.41"
	set $emissiveAnimSpeed "2.66"
	set $emissiveAnimScale "14.4"
}



