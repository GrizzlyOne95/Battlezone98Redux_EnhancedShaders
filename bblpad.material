import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"


material bblpad : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bblpad_D.dds
	set_texture_alias NormalMap bblpad_n.dds
	set_texture_alias SpecularMap bblpad_S.dds
	set_texture_alias EmissiveMap ablpad_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.44"
	set $emissiveAnimSpeed "2.95"
	set $emissiveAnimScale "7.7"
}


