import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material gmine00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap gmine00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap gmine00_S.dds
	set_texture_alias EmissiveMap proxmine00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.56"
	set $emissiveAnimSpeed "0.94"
	set $emissiveAnimScale "15.5"
}



