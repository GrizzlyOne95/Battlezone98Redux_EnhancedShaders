material UITexMat
{
	technique
	{
		pass
		{
			vertex_program_ref CR_UITexMat_vertex
			{
			}
			fragment_program_ref CR_UITexMat_fragment
			{
			} 

			lighting off
			scene_blend alpha_blend
			depth_check off
			depth_write off

			texture_unit
			{
				tex_address_mode clamp
				filtering linear linear none
			}
		}
	}
}

