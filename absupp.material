import * from "CR_BZBase.material"

material absupp : CR_BZBase
{
	set_texture_alias DiffuseMap absupp_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap absupp_S.dds
	set_texture_alias EmissiveMap absupp_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}



