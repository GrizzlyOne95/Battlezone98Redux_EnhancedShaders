import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material absupp : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap absupp_D.dds
	set_texture_alias NormalMap absupp_n.dds
	set_texture_alias SpecularMap absupp_S.dds
	set_texture_alias EmissiveMap absupp_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.58"
	set $emissiveAnimSpeed "2.05"
	set $emissiveAnimScale "17.4"
}



