import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sblpad : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sblpad_d.dds
	set_texture_alias NormalMap sblpad_n.dds
	set_texture_alias SpecularMap sblpad_S.dds
	set_texture_alias EmissiveMap sblpad_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.41"
	set $emissiveAnimSpeed "2.64"
	set $emissiveAnimScale "16.1"
}






