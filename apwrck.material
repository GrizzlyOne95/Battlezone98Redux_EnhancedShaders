import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material apwrck00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap apwrck00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap apwrck00_S.dds
	set_texture_alias EmissiveMap apwrck00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.16"
	set $emissiveAnimSpeed "1.2"
	set $emissiveAnimScale "9.9"
}

