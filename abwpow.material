import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abwpow : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abwpow_D.dds
	set_texture_alias NormalMap abwpow_n.dds
	set_texture_alias SpecularMap abwpow_S.dds
	set_texture_alias EmissiveMap abwpow_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.55"
	set $emissiveAnimSpeed "1.31"
	set $emissiveAnimScale "16.4"
}

