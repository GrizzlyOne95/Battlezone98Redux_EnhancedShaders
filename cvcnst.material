import * from "CR_BZBase.material"

material cvcnst : CR_BZBase
{
	set_texture_alias DiffuseMap cvcnst_d.dds
	set_texture_alias NormalMap cvcnst_N.dds
	set_texture_alias SpecularMap cvcnst_S.dds
	set_texture_alias EmissiveMap cvcnst_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}








