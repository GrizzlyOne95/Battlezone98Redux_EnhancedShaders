import * from "CR_BZTerrainBase.material"

material IO_DETAIL_ATLAS : CR_BZTerrainBase
{
	set_texture_alias DiffuseMap io_atlas_d.dds
	set_texture_alias DetailMap io_detail.dds
	set_texture_alias NormalMap io_atlas_n.dds
	set_texture_alias SpecularMap io_atlas_s.dds
	set_texture_alias EmissiveMap io_atlas_e.dds
	
	set $specular ".25 .25 .25"
	set $shininess "63"
}




