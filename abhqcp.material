import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abhqcp : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abhqcp_D.dds
	set_texture_alias NormalMap abhqcp_n.dds
	set_texture_alias SpecularMap abhqcp_S.dds
	set_texture_alias EmissiveMap abhqcp_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.23"
	set $emissiveAnimSpeed "0.95"
	set $emissiveAnimScale "8.3"
}

