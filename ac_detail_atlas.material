import * from "CR_BZTerrainBase.material"

material AC_DETAIL_ATLAS : CR_BZTerrainBase
{
	set_texture_alias DiffuseMap achilles_atlas_d.dds
	set_texture_alias DetailMap ac_detail.dds
	set_texture_alias NormalMap achilles_atlas_n.dds
	set_texture_alias SpecularMap achilles_atlas_s.dds
	set_texture_alias EmissiveMap black.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".25 .25 .25"
	set $shininess "63"
}



