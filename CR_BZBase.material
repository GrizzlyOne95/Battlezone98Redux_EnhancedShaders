material CR_BZBaseDebug
{
	lod_values 150 250

    technique
    {
        scheme high		
        lod_index 0
		
		pass 
 		{
			diffuse 1 0 0 1
		}
    }
	
	technique
    {
        scheme high		
        lod_index 1
		
		pass 
 		{
		
			diffuse 0 1 0 1
		}
    }
	
	technique
