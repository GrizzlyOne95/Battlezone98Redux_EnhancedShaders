material CR_BZBase
{
	set $shininess "32"
    set $ambient "1 1 1"
    set $diffuse "1 1 1"
	set $specular "1 1 1"
	set $bias "0"
	set $glow "1 1 1"
	
	lod_values 250 300
	
    technique
    {
        scheme high-pssm
        lod_index 0
		pass : BZPassSchemeHighPSSM
 		{
		}
    }
	
	technique
    {
        scheme high-pssm
        lod_index 1		
		pass : BZPassSchemeMediumNoShadow
 		{
		}
    }
	
	technique
    {
        scheme high-pssm
        lod_index 2		
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme high		 	
        lod_index 0
		pass : BZPassSchemeHigh
 		{
		}
    }
	
	technique
    {
        scheme high		 	
        lod_index 1		
		pass : BZPassSchemeMediumNoShadow
 		{
		}
    }
	
	technique
    {
        scheme high	 	
        lod_index 2		
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme high-noshadow
        lod_index 0
		pass : BZPassSchemeHighNoShadow
 		{
		}
    }
	
	technique
    {
        scheme high-noshadow
        lod_index 1		
		pass : BZPassSchemeMediumNoShadow
 		{
		}
    }
	
	technique
    {
        scheme high-noshadow
        lod_index 2		
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

     technique
     {
        scheme medium-pssm
        lod_index 0	  
		pass : BZPassSchemeMediumPSSM
 		{
		}
     }
	 
	technique
    {
        scheme medium-pssm
        lod_index 1	  
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

	technique
    {
        scheme medium-pssm
        lod_index 2
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

     technique
     {
        scheme medium	 	
        lod_index 0	  
		pass : BZPassSchemeMedium
 		{
		}
     }
	 
	technique
    {
        scheme medium		 	
        lod_index 1	  
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

	technique
    {
        scheme medium		 	
        lod_index 2
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

     technique
     {
        scheme medium-noshadow
        lod_index 0	  
		pass : BZPassSchemeMediumNoShadow
 		{
		}
     }
	 
	technique
    {
        scheme medium-noshadow
        lod_index 1	  
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

	technique
    {
        scheme medium-noshadow
        lod_index 2
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-pssm
        lod_index 0
		pass : BZPassSchemeLowPSSM
 		{
		}
    }
	 
    technique
    {
        scheme low-pssm
        lod_index 1
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low-pssm
        lod_index 2
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }
	  
    technique
    {
        scheme low
        lod_index 0
		pass : BZPassSchemeLow
 		{
		}
    }
	 
    technique
    {
        scheme low		  
        lod_index 1
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme low		  
        lod_index 2
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }
	  
    technique
    {
        scheme low-noshadow
        lod_index 0
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }
	 
    technique
    {
        scheme low-noshadow
        lod_index 1
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }
    technique
    {
        scheme low-noshadow
        lod_index 2
		pass : BZPassSchemeLowNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-pssm
        lod_index 0
		pass : BZPassSchemeLowestPSSM
 		{
		}
    }
	 
    technique
    {
        scheme lowest-pssm
        lod_index 1
		pass : BZPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest-pssm
        lod_index 2
		pass : BZPassSchemeLowestNoShadow
 		{
		}
    }
	  
    technique
    {
        scheme lowest
        lod_index 0
		pass : BZPassSchemeLowest
 		{
		}
    }
	 
    technique
    {
        scheme lowest		  
        lod_index 1
		pass : BZPassSchemeLowestNoShadow
 		{
		}
    }

    technique
    {
        scheme lowest		  
        lod_index 2
		pass : BZPassSchemeLowestNoShadow
 		{
		}
    }
	  
    technique
    {
        scheme lowest-noshadow
        lod_index 0
		pass : BZPassSchemeLowestNoShadow
 		{
