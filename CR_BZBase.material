material CR_BZBaseCockpit
{
	receive_shadows off

	set $shininess "32"
    set $ambient "1 1 1"
    set $diffuse "1 1 1"
	set $specular "1 1 1"
	set $bias "0"
	set $glow "1 1 1"
	
    technique
