import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bbcomm : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbcomm_D.dds
	set_texture_alias NormalMap bbcomm_n.dds
	set_texture_alias SpecularMap bbcomm_S.dds
	set_texture_alias EmissiveMap bbcomm_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.85"
	set $emissiveAnimSpeed "0.56"
	set $emissiveAnimScale "10.3"
}




