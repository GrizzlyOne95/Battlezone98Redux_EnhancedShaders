import * from "CR_BZBase.material"

material bbcomm : CR_BZBase
{
	set_texture_alias DiffuseMap bbcomm_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap bbcomm_S.dds
	set_texture_alias EmissiveMap bbcomm_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}




