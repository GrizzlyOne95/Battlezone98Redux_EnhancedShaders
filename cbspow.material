import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material CBSPOW : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbspow_d.dds
	set_texture_alias NormalMap cbspow_n.dds
	set_texture_alias SpecularMap cbspow_S.dds
	set_texture_alias EmissiveMap cbspow_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.2"
	set $emissiveAnimSpeed "2.55"
	set $emissiveAnimScale "11.8"
}





