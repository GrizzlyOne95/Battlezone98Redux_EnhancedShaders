import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"


material bbsupp : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbsupp_D.dds
	set_texture_alias NormalMap bbsupp_n.dds
	set_texture_alias SpecularMap bbsupp_S.dds
	set_texture_alias EmissiveMap absupp_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.2"
	set $emissiveAnimSpeed "2.7"
	set $emissiveAnimScale "5.7"
}


