import * from "CR_BZBase.material"


material bbsupp : CR_BZBase
{
	set_texture_alias DiffuseMap bbsupp_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap bbsupp_S.dds
	set_texture_alias EmissiveMap absupp_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}


