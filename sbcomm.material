import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material SBCOMM : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbcomm_d.dds
	set_texture_alias NormalMap sbcomm_n.dds
	set_texture_alias SpecularMap sbcomm_S.dds
	set_texture_alias EmissiveMap sbcomm_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.63"
	set $emissiveAnimSpeed "2.47"
	set $emissiveAnimScale "3.4"
}






