import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"


material bbwpow : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbwpow_D.dds
	set_texture_alias NormalMap bbwpow_n.dds
	set_texture_alias SpecularMap bbwpow_S.dds
	set_texture_alias EmissiveMap bbwpow_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.25"
	set $emissiveAnimSpeed "2.8"
	set $emissiveAnimScale "16.7"
}


