import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material hbtran1 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap hbtran_D.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap hbtran_S.dds
	set_texture_alias EmissiveMap hbtran_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.24"
	set $emissiveAnimSpeed "2.05"
	set $emissiveAnimScale "8.9"
}




