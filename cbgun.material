import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material cbgun : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbgun_d.dds
	set_texture_alias NormalMap cbgun_n.dds
	set_texture_alias SpecularMap cbgun_S.dds
	set_texture_alias EmissiveMap cbgun_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.48"
	set $emissiveAnimSpeed "1.89"
	set $emissiveAnimScale "7.6"
}





