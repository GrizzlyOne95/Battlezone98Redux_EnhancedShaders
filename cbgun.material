import * from "CR_BZBase.material"

material cbgun : CR_BZBase
{
	set_texture_alias DiffuseMap cbgun_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap cbgun_S.dds
	set_texture_alias EmissiveMap cbgun_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}





