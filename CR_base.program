//FRAGMENT PROGRAMS


//GLSLES VERSIONS

//LOWEST

fragment_program CR_BaseLowestNoShadow_fragmentGLSLES glsles
{
	source base-fragment.glsles
	syntax glsles
	entry_point main

	preprocessor_defines VERTEX_LIGHTING=1,MAX_LIGHTS=1,EMISSIVEMAP_ENABLED=1
	default_params
	{
		param_named diffuseMap int 0
		param_named emissiveMap int 3
	}
}

fragment_program CR_BaseLowestShadow_fragmentGLSLES glsles
{
	source base-fragment.glsles
	syntax glsles
	entry_point main

	preprocessor_defines VERTEX_LIGHTING=1,MAX_LIGHTS=1,SHADOWRECEIVER=1,PCF_SIZE=2,EMISSIVEMAP_ENABLED=1
	default_params
	{
		param_named diffuseMap int 0
		param_named emissiveMap int 3
		param_named shadowMap1 int 4
	}
}

fragment_program CR_BaseLowestPSSM_fragmentGLSLES glsles
{
	source base-fragment.glsles
	syntax glsles
	entry_point main

	preprocessor_defines VERTEX_LIGHTING=1,MAX_LIGHTS=1,SHADOWRECEIVER=1,PSSM_ENABLED=1,PCF_SIZE=2,EMISSIVEMAP_ENABLED=1
	default_params
	{
		param_named diffuseMap int 0
		param_named emissiveMap int 3
		param_named shadowMap1 int 4
		param_named shadowMap2 int 5
		param_named shadowMap3 int 6
