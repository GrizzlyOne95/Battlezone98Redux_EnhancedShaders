//VERTEX PROGRAMS


//GLSLES VERSIONS

//LOWEST

vertex_program CR_BaseLowestNoShadow_vertexGLSLES glsles
{
	source base-vertex.glsles
	syntax glsles
	entry_point main

	preprocessor_defines VERTEX_LIGHTING=1,MAX_LIGHTS=1
}

vertex_program CR_BaseLowestShadow_vertexGLSLES glsles
{
	source base-vertex.glsles
	syntax glsles
	entry_point main

	preprocessor_defines VERTEX_LIGHTING=1,MAX_LIGHTS=1,SHADOWRECEIVER=1
}

