import * from "CR_BZBase.material"

material oblemc : CR_BZBase
{
	set_texture_alias DiffuseMap oblemb_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap oblemb_S.dds
	set_texture_alias EmissiveMap oblemb_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}







