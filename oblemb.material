import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material oblemb00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap oblemb00_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap oblemb00_S.dds
	set_texture_alias EmissiveMap black.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.31"
	set $emissiveAnimSpeed "0.75"
	set $emissiveAnimScale "3.7"
}





