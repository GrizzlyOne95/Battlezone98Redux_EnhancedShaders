import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material cbport : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbport_d.dds
	set_texture_alias NormalMap cbport_n.dds
	set_texture_alias SpecularMap cbport_S.dds
	set_texture_alias EmissiveMap cbport_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.2"
	set $emissiveAnimSpeed "2.64"
	set $emissiveAnimScale "14.3"
}





