import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bvslf00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bvslf_D.dds
	set_texture_alias NormalMap bvslf_N.dds
	set_texture_alias SpecularMap bvslf_S.dds
	set_texture_alias EmissiveMap bvslf_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.4"
	set $emissiveAnimSpeed "1.41"
	set $emissiveAnimScale "15.7"
}





