import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material obtags : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap obpowr00_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap obpowr00_S.dds
	set_texture_alias EmissiveMap obpowr00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.21"
	set $emissiveAnimSpeed "1.04"
	set $emissiveAnimScale "5.3"
}




