import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bvrecy00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bvrecy_D.dds
	set_texture_alias NormalMap bvrecy_N.dds
	set_texture_alias SpecularMap bvrecy_S.dds
	set_texture_alias EmissiveMap bvrecy_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.43"
	set $emissiveAnimSpeed "0.65"
	set $emissiveAnimScale "19.5"
}





