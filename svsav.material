import * from "CR_BZBase.material"

material svsav : CR_BZBase
{
	set_texture_alias DiffuseMap svsav_d.dds
	set_texture_alias NormalMap svsav_N.dds
	set_texture_alias SpecularMap svsav_S.dds
	set_texture_alias EmissiveMap svsav_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}









