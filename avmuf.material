import * from "CR_BZBase.material"

material avmuf00 : CR_BZBase
{
	set_texture_alias DiffuseMap avmuf_D.dds
	set_texture_alias NormalMap avmuf_N.dds
	set_texture_alias SpecularMap avmuf_S.dds
	set_texture_alias EmissiveMap avmuf_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}



