import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material avtest00 : CR_BZBasePaintedMetalSkinned
{
	set_texture_alias DiffuseMap avtest_D.dds
	set_texture_alias NormalMap avtest_N.dds
	set_texture_alias SpecularMap avtest_S.dds
	set_texture_alias EmissiveMap black.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.84"
	set $emissiveAnimSpeed "1.23"
	set $emissiveAnimScale "16.3"
}



