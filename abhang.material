import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abhang00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abhang_D.dds
	set_texture_alias NormalMap abhang_n.dds
	set_texture_alias SpecularMap abhang_S.dds
	set_texture_alias EmissiveMap abhang_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.63"
	set $emissiveAnimSpeed "2.42"
	set $emissiveAnimScale "17.1"
}



