import * from "CR_BZBase.material"

material CBLASR : CR_BZBase
{
	set_texture_alias DiffuseMap cblasr_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap cblasr_S.dds
	set_texture_alias EmissiveMap cblasr_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
}





