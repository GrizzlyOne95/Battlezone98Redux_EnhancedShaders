import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material CBLASR : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cblasr_d.dds
	set_texture_alias NormalMap cblasr_n.dds
	set_texture_alias SpecularMap cblasr_S.dds
	set_texture_alias EmissiveMap cblasr_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.5"
	set $emissiveAnimSpeed "2.41"
	set $emissiveAnimScale "18.8"
}





