import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material hvsrb : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap hvsav00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap hvsav00_S.dds
	set_texture_alias EmissiveMap hvsav00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.75"
	set $emissiveAnimSpeed "1.58"
	set $emissiveAnimScale "9.2"
}







