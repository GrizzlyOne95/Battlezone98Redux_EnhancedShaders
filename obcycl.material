import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material obcycl00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap obcycl00_d.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap obcycl00_S.dds
	set_texture_alias EmissiveMap obcycl00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.3"
	set $emissiveAnimSpeed "1.82"
	set $emissiveAnimScale "9.8"
}





