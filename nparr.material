import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material nparr00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap nparr00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap nparr00_S.dds
	set_texture_alias EmissiveMap nparr00_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.64"
	set $emissiveAnimSpeed "2.14"
	set $emissiveAnimScale "9.1"
}










