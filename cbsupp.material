import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material cbsupp00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbsupp_d.dds
	set_texture_alias NormalMap cbsupp_n.dds
	set_texture_alias SpecularMap cbsupp_S.dds
	set_texture_alias EmissiveMap cbsupp_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.72"
	set $emissiveAnimSpeed "2.22"
	set $emissiveAnimScale "4.3"
}





