import * from "CR_BZBase.material"

material magpush : CR_BZBase
{
	set_texture_alias DiffuseMap gmine00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap gmine00_s.dds
	set_texture_alias EmissiveMap gmine00_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $bias "0"
}




