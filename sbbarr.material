import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material sbbarr : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap sbbarr_d.dds
	set_texture_alias NormalMap sbbarr_n.dds
	set_texture_alias SpecularMap sbbarr_S.dds
	set_texture_alias EmissiveMap sbbarr_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.79"
	set $emissiveAnimSpeed "2.4"
	set $emissiveAnimScale "14.4"
}



