import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material obheph00 : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap obheph00.dds
	set_texture_alias NormalMap flat_N.dds
	set_texture_alias SpecularMap black.dds
	set_texture_alias EmissiveMap black.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.48"
	set $emissiveAnimSpeed "1.43"
	set $emissiveAnimScale "15.4"
}










