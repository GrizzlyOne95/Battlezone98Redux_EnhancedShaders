material Glow/Downsample
{
	technique
	{
		pass
		{
			cull_hardware none
			cull_software none
			depth_check off
            polygon_mode_overrideable false
 
  			vertex_program_ref CR_StdQuad_Tex2a_vp
			{
			}
			
			fragment_program_ref CR_GlowDownsample_fp
			{
			}
 
			texture_unit map
			{
					tex_coord_set 0
					tex_address_mode clamp
					filtering bilinear
			}
		}
	}
}
 

