import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material bbhang : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap bbhang_D.dds
	set_texture_alias NormalMap bbhang_n.dds
	set_texture_alias SpecularMap bbhang_S.dds
	set_texture_alias EmissiveMap bbhang_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.16"
	set $emissiveAnimSpeed "2.84"
	set $emissiveAnimScale "6.0"
}





