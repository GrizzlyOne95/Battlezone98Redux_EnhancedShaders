import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material CBHANG : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap cbhang_d.dds
	set_texture_alias NormalMap cbhang_n.dds
	set_texture_alias SpecularMap cbhang_S.dds
	set_texture_alias EmissiveMap cbhang_e.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.26"
	set $emissiveAnimSpeed "2.7"
	set $emissiveAnimScale "4.1"
}





