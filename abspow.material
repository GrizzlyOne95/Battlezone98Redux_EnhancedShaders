import * from "CR_BZBase.material"
import * from "CR_BZBasePaintedMetal.material"

material abspow : CR_BZBasePaintedMetal
{
	set_texture_alias DiffuseMap abspow_D.dds
	set_texture_alias NormalMap abspow_n.dds
	set_texture_alias SpecularMap abspow_S.dds
	set_texture_alias EmissiveMap abspow_E.dds
	
	set $diffuse "1 1 1"
	set $ambient "1 1 1"
	set $specular ".7 .7 .7"
	set $shininess "127"
	set $emissiveAnimStrength "0.52"
	set $emissiveAnimSpeed "0.48"
	set $emissiveAnimScale "18.9"
}



